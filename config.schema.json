{
  "pluginAlias": "HonPlatform",
  "pluginType": "platform",
  "singular": true,
  "schema": {
    "type": "object",
    "properties": {
      "name": {
        "title": "Name",
        "type": "string",
        "default": "hOn"
      },
      "email": {
        "title": "hOn Email",
        "type": "string",
        "required": true,
        "format": "email"
      },
      "password": {
        "title": "hOn Password",
        "type": "string",
        "required": true
      },
      "pollingInterval": {
        "title": "Polling Interval (seconds)",
        "type": "integer",
        "default": 30,
        "minimum": 10,
        "maximum": 300,
        "description": "How often to refresh device status from the hOn cloud"
      }
    }
  }
}
